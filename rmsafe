#!/usr/bin/env bash
#
# rmsafe - Safety wrapper for destructive Linux commands
#
# rmsafe intercepts dangerous operations (rm -rf /, dd to disks, etc.)
# and requires the user to type a random confirmation phrase before
# proceeding. This prevents catastrophic accidents while allowing
# deliberate destructive operations.
#
# Usage:
#   rmsafe [options] <command> [args...]
#
# Options:
#   --force, -f    Skip confirmation (for unattended scripts)
#   --dry-run, -n  Check without executing
#   --init         Print shell aliases for automatic protection
#   --help, -h     Show this help message
#
# Examples:
#   rmsafe rm -rf /etc           # Requires confirmation
#   rmsafe rm -rf /var/log/*     # Runs normally (safe operation)
#   rmsafe dd if=/dev/zero of=/dev/sda bs=4M  # Requires confirmation
#   eval "$(rmsafe --init)"      # Install aliases in current shell
#
# Installation:
#   Add to ~/.bashrc or ~/.zshrc:
#     eval "$(rmsafe --init)"
#
# Configuration:
#   Set $RMSAFE_CRITICAL_PATHS to override protected paths (colon-separated)
#   Set $RMSAFE_SKIP to a regex matching command names to always allow

set -euo pipefail

# ──────────────────────────────────────────────
# Default critical paths
# ──────────────────────────────────────────────

if [ -n "${RMSAFE_CRITICAL_PATHS:-}" ]; then
    IFS=':' read -ra CRITICAL_PATHS <<< "$RMSAFE_CRITICAL_PATHS"
else
    CRITICAL_PATHS=(
        / /etc /boot /lib /lib32 /lib64
        /usr /bin /sbin /sys /proc /dev
        /run /root
    )
fi

# ──────────────────────────────────────────────
# Output helpers (color when stderr is a terminal)
# ──────────────────────────────────────────────

if [ -t 2 ]; then
    RED='\033[1;31m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'
    BLUE='\033[1;34m'; BOLD='\033[1m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; NC=''
fi

error()   { printf "${RED}ERROR: %s${NC}\n" "$*" >&2; }
warn()    { printf "${YELLOW}WARNING: %s${NC}\n" "$*" >&2; }
success() { printf "${GREEN}%s${NC}\n" "$*" >&2; }
info()    { printf "${BLUE}%s${NC}\n" "$*" >&2; }
emph()    { printf "${BOLD}%s${NC}\n" "$*" >&2; }

# ──────────────────────────────────────────────
# Random confirmation phrase generator
# ──────────────────────────────────────────────

generate_phrase() {
    local words=()

    if command -v shuf &>/dev/null && [ -f /usr/share/dict/words ]; then
        while IFS= read -r word; do
            word=$(tr '[:upper:]' '[:lower:]' <<< "$word" | sed 's/[^a-z]//g')
            [ -n "$word" ] && words+=("$word")
        done < <(shuf -n 3 /usr/share/dict/words 2>/dev/null)
    elif [ -f /usr/share/dict/words ]; then
        local dict_size
        dict_size=$(wc -l < /usr/share/dict/words 2>/dev/null) || dict_size=0
        if [ "$dict_size" -gt 100 ]; then
            local i line word
            for i in 1 2 3; do
                line=$((RANDOM * dict_size / 32767 + 1))
                word=$(sed -n "${line}p" /usr/share/dict/words 2>/dev/null)
                word=$(tr '[:upper:]' '[:lower:]' <<< "$word" | sed 's/[^a-z]//g')
                [ -n "$word" ] && words+=("$word")
            done
        fi
    fi

    if [ ${#words[@]} -ge 3 ]; then
        local IFS='-'
        echo "${words[*]}"
    else
        printf 'confirm-%04x-%04x-%04x\n' $RANDOM $RANDOM $RANDOM
    fi
}

# ──────────────────────────────────────────────
# Path safety checks
# ──────────────────────────────────────────────

# Returns 0 if the given path is a critical system path
is_critical_path() {
    local target="$1"
    local resolved

    # Direct root check before any stripping
    if [ "$target" = "/" ] || [ "$target" = "/*" ]; then
        return 0
    fi

    # Resolve to real absolute path when possible
    if [ -e "$target" ] || [ -L "$target" ]; then
        resolved=$(realpath "$target" 2>/dev/null || echo "$target")
    else
        resolved="$target"
    fi

    # Exact match against critical paths
    for p in "${CRITICAL_PATHS[@]}"; do
        [ "$resolved" = "$p" ] && return 0
    done

    # Match glob patterns like /etc/* or /*
    local stripped="${target%/}"
    for p in "${CRITICAL_PATHS[@]}"; do
        [ "$stripped" = "$p/*" ] && return 0
    done

    return 1
}

# ──────────────────────────────────────────────
# Command-specific danger detection
# ──────────────────────────────────────────────

# rm -rf with critical path target
check_rm() {
    local args=("$@")
    local has_recursive=false

    for arg in "${args[@]}"; do
        if [[ "$arg" == @(-r|-R|--recursive) ]] || [[ "$arg" =~ ^-[a-zA-Z]*[rR][a-zA-Z]*$ ]]; then
            has_recursive=true
            break
        fi
    done

    if ! $has_recursive; then
        return 1
    fi

    for arg in "${args[@]}"; do
        [[ "$arg" == -* ]] && continue
        is_critical_path "$arg" && return 0
    done

    return 1
}

# dd writing directly to a block device
check_dd() {
    local args=("$@")
    for arg in "${args[@]}"; do
        if [[ "$arg" =~ ^of=/dev/(sd|nvme|mmcblk|vd|hd|loop| mapper/) ]]; then
            return 0
        fi
    done
    return 1
}

# mkfs* targeting a block device
check_mkfs() {
    local args=("$@")
    for arg in "${args[@]}"; do
        if [[ "$arg" =~ ^/dev/(sd|nvme|mmcblk|vd|hd|loop| mapper/) ]]; then
            return 0
        fi
    done
    return 1
}

# Recursive chmod/chown on critical path
check_chmod_chown() {
    local args=("$@")
    local has_recursive=false
    local paths=()

    for arg in "${args[@]}"; do
        if [[ "$arg" == @(-R|--recursive) ]] || [[ "$arg" =~ ^-[a-zA-Z]*R[a-zA-Z]*$ ]]; then
            has_recursive=true
        fi
    done

    if ! $has_recursive; then
        return 1
    fi

    for arg in "${args[@]}"; do
        [[ "$arg" != -* ]] && paths+=("$arg")
    done

    for path in "${paths[@]}"; do
        is_critical_path "$path" && return 0
    done

    return 1
}

# mv of a critical path
check_mv() {
    local args=("$@")
    local paths=()

    for arg in "${args[@]}"; do
        [[ "$arg" != -* ]] && paths+=("$arg")
    done

    for ((i=0; i<${#paths[@]}-1; i++)); do
        is_critical_path "${paths[i]}" && return 0
    done

    return 1
}

# find on critical path with -delete or -exec
check_find() {
    local args=("$@")
    local has_delete=false
    local has_exec=false
    local path=""

    for arg in "${args[@]}"; do
        [[ "$arg" == "-delete" ]] && has_delete=true
        [[ "$arg" == -exec ]] && has_exec=true
    done

    if ! $has_delete && ! $has_exec; then
        return 1
    fi

    for arg in "${args[@]}"; do
        if [[ "$arg" != -* ]]; then
            path="$arg"
            break
        fi
    done

    [ -n "$path" ] && is_critical_path "$path" && return 0
    return 1
}

# ──────────────────────────────────────────────
# Danger detection dispatcher
# ──────────────────────────────────────────────

is_dangerous() {
    local cmd
    cmd=$(basename "$1")
    shift
    local args=("$@")

    # Allowlist via RMSAFE_SKIP env var
    if [ -n "${RMSAFE_SKIP:-}" ] && [[ "$cmd" =~ $RMSAFE_SKIP ]]; then
        return 1
    fi

    case "$cmd" in
        rm)     check_rm "${args[@]}" ;;
        dd)     check_dd "${args[@]}" ;;
        mkfs*)  check_mkfs "${args[@]}" ;;
        mke2fs|mkswap|mkfs) check_mkfs "${args[@]}" ;;
        chmod|chown) check_chmod_chown "${args[@]}" ;;
        mv)     check_mv "${args[@]}" ;;
        find)   check_find "${args[@]}" ;;
        *)
            for arg in "${args[@]}"; do
                [[ "$arg" == -* ]] && continue
                is_critical_path "$arg" && return 0
            done
            return 1
            ;;
    esac
}

# ──────────────────────────────────────────────
# Confirmation prompt
# ──────────────────────────────────────────────

prompt_confirmation() {
    local command_desc="$1"
    local phrase
    local user_input

    phrase=$(generate_phrase)

    echo >&2
    error "═══════════════════════════════════════════"
    error "  DANGEROUS OPERATION DETECTED"
    error "═══════════════════════════════════════════"
    echo >&2
    warn "  Command: ${command_desc}"
    echo >&2
    error "  This action could CRIPPLE or DESTROY your system!"
    echo >&2
    emph "  To proceed, type the following phrase exactly:"
    echo >&2
    success "      ${phrase}"
    echo >&2
    printf "  > " >&2
    read -r user_input

    if [ "$user_input" = "$phrase" ]; then
        echo >&2
        success "Confirmation accepted. Executing..."
        echo >&2
        return 0
    else
        echo >&2
        error "Confirmation failed. Operation aborted."
        echo >&2
        return 1
    fi
}

# ──────────────────────────────────────────────
# Usage message
# ──────────────────────────────────────────────

usage() {
    cat >&2 <<'EOF'
Usage: rmsafe [options] <command> [args...]

Safety wrapper for destructive Linux commands. Prevents accidental
catastrophic operations by requiring a random phrase confirmation.

Options:
  --force, -f       Skip confirmation (use with caution)
  --dry-run, -n     Check without executing
  --init            Print shell aliases for automatic protection
  --help, -h        Show this help message

Examples:
  rmsafe rm -rf /etc           # Requires confirmation
  rmsafe rm -rf /var/log/*     # Safe - runs without confirmation
  rmsafe dd if=/dev/zero of=/dev/sda bs=4M  # Requires confirmation

Installation:
  eval "$(rmsafe --init)"      # Add to ~/.bashrc or ~/.zshrc

Environment:
  RMSAFE_CRITICAL_PATHS        Colon-separated list of paths to protect
  RMSAFE_SKIP                  Regex: command names to always allow
EOF
}

# ──────────────────────────────────────────────
# Entry point
# ──────────────────────────────────────────────

main() {
    local force=false
    local dry_run=false

    # Parse rmsafe's own options
    while [ $# -gt 0 ]; do
        case "$1" in
            --force|-f)   force=true; shift ;;
            --dry-run|-n) dry_run=true; shift ;;
            --init)
                me="${BASH_SOURCE[0]:-$0}"
                cat <<ALIASES
alias rm='${me} rm'
alias dd='${me} dd'
alias mkfs='${me} mkfs'
alias mke2fs='${me} mke2fs'
alias mkswap='${me} mkswap'
alias chmod='${me} chmod'
alias chown='${me} chown'
alias mv='${me} mv'
alias find='${me} find'
alias mkfs.ext2='${me} mkfs.ext2'
alias mkfs.ext3='${me} mkfs.ext3'
alias mkfs.ext4='${me} mkfs.ext4'
alias mkfs.btrfs='${me} mkfs.btrfs'
alias mkfs.xfs='${me} mkfs.xfs'
ALIASES
                return 0
                ;;
            --help|-h)    usage; return 0 ;;
            --)           shift; break ;;
            -*)
                error "Unknown option: $1"
                usage
                return 1
                ;;
            *) break ;;
        esac
    done

    if [ $# -eq 0 ]; then
        error "No command specified."
        usage
        return 1
    fi

    local cmd="$1"
    shift
    local cmd_args=("$@")

    if ! $force && is_dangerous "$cmd" "${cmd_args[@]}"; then
        local desc="$cmd ${cmd_args[*]}"
        if $dry_run; then
            error "BLOCKED (dry-run): $desc"
            return 1
        fi
        prompt_confirmation "$desc" || return 1
    elif $dry_run; then
        success "OK (dry-run): $cmd ${cmd_args[*]}"
        return 0
    fi

    if ! command -v "$cmd" &>/dev/null; then
        error "Command not found: $cmd"
        return 127
    fi

    exec "$cmd" "${cmd_args[@]}"
}

main "$@"
